{
  "expo": {
    "name": "Kurbada",
    "slug": "kurbada",
    "version": "0.1.2",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "androidNavigationBar": {
      "backgroundColor": "#0D0D0D",
      "barStyle": "light-content"
    },
    "scheme": "kurbada",
    "userInterfaceStyle": "dark",
    "ios": {
      "icon": "./assets/images/logo.png",
      "supportsTablet": false,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Kurbada needs photo access so riders can pick a photo and share ride overlays to Instagram.",
        "NSPhotoLibraryAddUsageDescription": "Kurbada saves your exported ride overlays locally before sharing them to Instagram.",
        "UIBackgroundModes": ["location", "location"]
      },
      "bundleIdentifier": "com.samueluy.kurbada"
    },
    "android": {
      "package": "com.samueluy.kurbada",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/logo-white-transparent.png",
        "monochromeImage": "./assets/images/logo-white-transparent.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "image": "./assets/images/splash-screen-square.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Kurbada tracks your location during rides to record your route, even when the app is in the background.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      "expo-sharing",
      "expo-secure-store",
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "Kurbada uses your photos to create shareable ride cards.",
          "cameraPermission": false
        }
      ],
      ["@rnmapbox/maps", {}],
      "@react-native-community/datetimepicker",
      "expo-asset",
      "expo-build-properties"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b2da3e1e-40b8-492f-bf47-8f7af19b8e8c"
      }
    }
  }
}
